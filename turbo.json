{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": [
    "API_URL",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "test": {
      "outputs": [
        "coverage/**"
      ],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}